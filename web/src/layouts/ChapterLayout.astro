---
import BaseLayout from './BaseLayout.astro';
import { type Lang, defaultLang } from '../i18n/ui';

interface Props {
  title: string;
  summary?: string;
  part?: string;
  lang?: Lang;
}
const { title, summary, part, lang = defaultLang } = Astro.props;
---

<BaseLayout title={`${title} · GDL`} description={summary} lang={lang}>
  <article class="prose">
    {part && <p class="eyebrow">{part}</p>}
    <h1>{title}</h1>
    <slot />
  </article>

  <style>
    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 0.72rem;
      font-family: var(--font-display);
      color: var(--color-gold);
      margin-bottom: 0;
    }
    article { padding: 2rem 0; }
  </style>
</BaseLayout>
