---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container inner">
    <a class="org" href="https://fractalmanifold.com">
      <img src="/logo.png" alt="" width="22" height="22" />
      <span>A Fractal Manifold project</span>
    </a>
    <p>
      © {year} · Geometric Deep Learning ·
      <a href="https://github.com/fractal-manifold/gdl">Source on GitHub</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 5rem;
    padding: 2.5rem 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .org {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }
  .org:hover { text-decoration: none; color: var(--color-gold); }
  .site-footer p { margin: 0; }
</style>
