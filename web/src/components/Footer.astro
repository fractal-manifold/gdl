---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell">
    <p>
      © {year} <span class="org">Fractal Manifold</span>. {t('footer.rights')}
      <span class="sep" aria-hidden="true">·</span>
      <a href="#top">{t('footer.top')}</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href="mailto:contact@fractalmanifold.com">contact@fractalmanifold.com</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 0;
    background: var(--color-bg);
  }
  .site-footer p {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }
  .org { color: var(--color-text-secondary); }
  .sep { margin: 0 0.5rem; color: var(--color-text-dim); }
  .site-footer a { color: var(--color-text-muted); transition: color 0.3s ease; }
  .site-footer a:hover { color: var(--color-gold); }
</style>
