---
import { getCollection } from 'astro:content';
import { type Lang, defaultLang, localizePath, useTranslations } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// The table of contents is driven by the chapter collection (filtered by
// language) so the homepage, the /chapters index and the LaTeX book stay in
// sync. Chapter ids are prefixed with the locale ("en/01-introduction").
const chapters = (await getCollection('chapters'))
  .filter((c) => c.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
const slugOf = (id: string) => id.replace(/^(en|es)\//, '');

// Decorative drifting equations — maths is language-neutral, kept as-is.
const heroMath = [
  { t: 'f(g·x) = g·f(x)', c: 'var(--color-gold)', s: 'top:16%;left:6%', d: '0s', dur: '15s', size: '1.05rem' },
  { t: 'Σ_{j∈𝒩(i)} m_ij', c: 'var(--color-purple-light)', s: 'top:70%;left:8%', d: '-4s', dur: '18s', size: '1rem' },
  { t: 'ρ(g) ∈ GL(V)', c: 'var(--color-purple-light)', s: 'top:24%;right:7%', d: '-6s', dur: '17s', size: '0.95rem' },
  { t: 'SO(3), SE(3)', c: 'var(--color-gold)', s: 'bottom:14%;right:12%', d: '-2s', dur: '19s', size: '1rem' },
  { t: '∇_M f', c: 'var(--color-gold-light)', s: 'top:46%;left:3%', d: '-7s', dur: '16s', size: '0.95rem' },
];

// Icons + accents are constant across languages; the copy comes from `tr`.
const gsMeta = [
  { accent: 'gold', icon: '<rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>' },
  { accent: 'purple', icon: '<polygon points="12 2 21 7 21 17 12 22 3 17 3 7"></polygon><line x1="12" y1="2" x2="12" y2="22"></line><line x1="3" y1="7" x2="21" y2="17"></line><line x1="21" y1="7" x2="3" y2="17"></line>' },
  { accent: 'gold', icon: '<circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>' },
  { accent: 'purple', icon: '<circle cx="6" cy="19" r="2"></circle><circle cx="18" cy="5" r="2"></circle><path d="M7.5 17.5C11 13 13 11 16.5 6.5"></path>' },
  { accent: 'gold', icon: '<circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>' },
];

const formatMeta = [
  { accent: 'gold', href: null, icon: '<rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path>' },
  { accent: 'gold', href: null, icon: '<polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect>' },
  { accent: 'purple', href: null, icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>' },
  { accent: 'purple', href: null, icon: '<circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>' },
];

// All translatable landing copy. The H1/cover keep the canonical book name
// "Geometric Deep Learning" in both languages (it matches the cover art).
const copy = {
  en: {
    heroEyebrow: 'Fractal Manifold Press · Book',
    heroTagline: 'A Mathematical Perspective',
    heroSub: 'A math-first treatment of deep learning on graphs, manifolds and groups — message passing, symmetry and equivariance from the ground up.',
    ctaGet: 'Get the book',
    ctaBrowse: 'Browse contents',
    heroBy: 'By the Fractal Manifold research team · Free to download',
    thesisEyebrow: '01 — The Thesis',
    thesisTitle: 'An Erlangen Programme for deep learning',
    thesisP1: 'Most successful neural networks share a hidden blueprint: they are built to respect the symmetries of the data they consume. A convolutional network is invariant to translation; a graph network to permutation; a spherical network to rotation.',
    thesisP2: 'Geometric Deep Learning makes that blueprint explicit. Starting from a small set of geometric priors — symmetry, scale separation and locality — it derives the architectures that dominate practice today, and points toward the ones that don’t yet exist.',
    thesisQuote: 'Symmetry is not a constraint on learning — it is the structure that makes learning possible.',
    gsEyebrow: '02 — The Five Gs',
    gsTitle: 'Five domains, one set of principles',
    gs: [
      { name: 'Geometry', desc: 'The domains of data. Riemannian manifolds, tangent spaces and curvature give a precise language for the space a signal lives on.' },
      { name: 'Groups', desc: 'The symmetries of data. Lie groups and representation theory — Peter–Weyl and Schur — yield the equivariant operators that respect them.' },
      { name: 'Graphs', desc: 'The discretisation of geometries. The graph Laplacian and spectral analysis turn continuous domains into computable, neighbourhood-preserving structures.' },
      { name: 'Geodesics', desc: 'Optimal paths and information propagation. Metrics, the exponential map and parallel transport — the geometric root of message passing.' },
      { name: 'Gauges', desc: 'Local invariances and coordinate freedoms. Principal bundles and connections handle the freedom to choose local reference frames.' },
    ],
    blueprintLabel: 'The blueprint',
    blueprintDesc: 'Each domain is a special case of one recipe: a symmetry group, a signal on a domain, and equivariant maps that commute with the group. Message passing is its common implementation.',
    contentsEyebrow: '03 — Contents',
    contentsTitle: 'Table of contents',
    contentsNote: 'Six chapters — from neural-network foundations through the geometric framework of the Five Gs to its convolutional and attention models. ',
    audienceEyebrow: "04 — Who it's for",
    audienceTitle: 'Written for builders and theorists alike',
    audience: [
      { title: 'Researchers', desc: 'A unifying language for architectures you already know, and a map of the open territory beyond them.' },
      { title: 'Engineers', desc: 'Principled reasons to choose one model over another, grounded in the structure of your own data.' },
      { title: 'Students', desc: 'A rigorous on-ramp: linear algebra and calculus in, modern deep learning out — with the maths kept honest.' },
    ],
    accessEyebrow: '05 — Get the book',
    accessTitle: 'Get the book',
    accessLead: 'The book is still being written. Free screen and print PDFs, an ePub for e-readers, and a bound edition on Amazon will all be published here as soon as the first release is ready.',
    formats: [
      { title: 'Screen PDF', desc: 'Optimised for reading on any screen', cta: 'Coming soon' },
      { title: 'Print PDF', desc: 'Print-ready, sized for 7×10″ paper', cta: 'Coming soon' },
      { title: 'ePub', desc: 'For Kindle, Kobo & e-readers', cta: 'Coming soon' },
      { title: 'Printed copy', desc: 'Order a bound edition on Amazon', cta: 'Coming soon' },
    ],
    accessFine: 'Digital formats will be published on GitHub Releases. The printed edition will link to Amazon.',
  },
  es: {
    heroEyebrow: 'Fractal Manifold Press · Libro',
    heroTagline: 'una perspectiva matemática',
    heroSub: 'Un tratamiento desde las matemáticas del aprendizaje profundo en grafos, variedades y grupos — paso de mensajes, simetría y equivariancia desde los cimientos.',
    ctaGet: 'Consigue el libro',
    ctaBrowse: 'Ver contenidos',
    heroBy: 'Por el equipo de investigación de Fractal Manifold · Descarga gratuita',
    thesisEyebrow: '01 — La tesis',
    thesisTitle: 'Un Programa de Erlangen para el aprendizaje profundo',
    thesisP1: 'La mayoría de las redes neuronales exitosas comparten un esquema oculto: están construidas para respetar las simetrías de los datos que consumen. Una red convolucional es invariante a la traslación; una red de grafos a la permutación; una red esférica a la rotación.',
    thesisP2: 'El aprendizaje profundo geométrico hace ese esquema explícito. Partiendo de un pequeño conjunto de priores geométricos — simetría, separación de escalas y localidad — deriva las arquitecturas que dominan la práctica actual, y apunta hacia las que aún no existen.',
    thesisQuote: 'La simetría no es una restricción para el aprendizaje — es la estructura que lo hace posible.',
    gsEyebrow: '02 — Las Cinco Ges',
    gsTitle: 'Cinco dominios, un mismo conjunto de principios',
    gs: [
      { name: 'Geometry', desc: 'Los dominios de los datos. Variedades de Riemann, espacios tangentes y curvatura dan un lenguaje preciso para el espacio en que vive una señal.' },
      { name: 'Groups', desc: 'Las simetrías de los datos. Grupos de Lie y teoría de representaciones —Peter–Weyl y Schur— producen los operadores equivariantes que las respetan.' },
      { name: 'Graphs', desc: 'La discretización de geometrías. El laplaciano del grafo y el análisis espectral convierten dominios continuos en estructuras computables que preservan la vecindad.' },
      { name: 'Geodesics', desc: 'Caminos óptimos y propagación de la información. Métricas, mapa exponencial y transporte paralelo — la raíz geométrica del paso de mensajes.' },
      { name: 'Gauges', desc: 'Invarianzas locales y libertad de coordenadas. Fibrados principales y conexiones manejan la libertad de elegir marcos de referencia locales.' },
    ],
    blueprintLabel: 'El esquema',
    blueprintDesc: 'Cada dominio es un caso particular de una misma receta: un grupo de simetría, una señal sobre un dominio y aplicaciones equivariantes que conmutan con el grupo. El paso de mensajes es su implementación común.',
    contentsEyebrow: '03 — Contenidos',
    contentsTitle: 'Tabla de contenidos',
    contentsNote: 'Seis capítulos — de los fundamentos de redes neuronales al marco geométrico de las Cinco Ges y sus modelos convolucionales y de atención. ',
    audienceEyebrow: '04 — Para quién es',
    audienceTitle: 'Escrito tanto para quienes construyen como para quienes teorizan',
    audience: [
      { title: 'Investigadores', desc: 'Un lenguaje unificador para arquitecturas que ya conoces, y un mapa del territorio abierto más allá de ellas.' },
      { title: 'Ingenieros', desc: 'Razones fundamentadas para elegir un modelo sobre otro, ancladas en la estructura de tus propios datos.' },
      { title: 'Estudiantes', desc: 'Una entrada rigurosa: entra álgebra lineal y cálculo, sale aprendizaje profundo moderno — con las matemáticas bien cuidadas.' },
    ],
    accessEyebrow: '05 — Consigue el libro',
    accessTitle: 'Consigue el libro',
    accessLead: 'El libro aún se está escribiendo. Los PDF gratuitos para pantalla e impresión, un ePub para lectores electrónicos y una edición encuadernada en Amazon se publicarán aquí en cuanto esté lista la primera versión.',
    formats: [
      { title: 'PDF de pantalla', desc: 'Optimizado para leer en cualquier pantalla', cta: 'Próximamente' },
      { title: 'PDF de impresión', desc: 'Listo para imprimir, en papel de 7×10″', cta: 'Próximamente' },
      { title: 'ePub', desc: 'Para Kindle, Kobo y lectores electrónicos', cta: 'Próximamente' },
      { title: 'Copia impresa', desc: 'Pide una edición encuadernada en Amazon', cta: 'Próximamente' },
    ],
    accessFine: 'Los formatos digitales se publicarán en GitHub Releases. La edición impresa enlazará a Amazon.',
  },
}[lang];

const fiveGs = gsMeta.map((m, i) => ({ ...m, ...copy.gs[i] }));
const formats = formatMeta.map((m, i) => ({ ...m, ...copy.formats[i] }));
---

<!-- ===================== HERO ===================== -->
<section class="hero">
  <div class="hero-orbs" aria-hidden="true">
    <div class="orb" style="width:520px;height:520px;opacity:0.4;background:radial-gradient(circle,#9333EA,transparent);top:-12%;left:-8%;animation:float-main 14s ease-in-out infinite"></div>
    <div class="orb" style="width:480px;height:480px;opacity:0.38;background:radial-gradient(circle,#F59E0B,transparent);bottom:-18%;right:-6%;animation:float-main 16s ease-in-out infinite reverse"></div>
    <div class="orb" style="width:300px;height:300px;opacity:0.3;background:radial-gradient(circle,#A855F7,transparent);top:30%;right:30%;animation:float-secondary 11s ease-in-out infinite;animation-delay:-3s"></div>
  </div>
  <div class="hero-math" aria-hidden="true">
    {heroMath.map((m) => (
      <span class="eq" style={`${m.s};color:${m.c};font-size:${m.size};animation:drift-eq ${m.dur} ease-in-out infinite;animation-delay:${m.d}`}>{m.t}</span>
    ))}
  </div>

  <div class="shell hero-inner">
    <div class="hero-text">
      <div class="eyebrow">{copy.heroEyebrow}</div>
      <h1 class="hero-title"><span class="gradient-text">Geometric Deep Learning</span></h1>
      <p class="hero-tagline">{copy.heroTagline}</p>
      <p class="hero-sub">{copy.heroSub}</p>
      <div class="hero-cta">
        <a class="btn btn-gold" href="#access">{copy.ctaGet}</a>
        <a class="btn btn-purple" href="#contents">{copy.ctaBrowse}</a>
      </div>
      <div class="hero-by">{copy.heroBy}</div>
    </div>

    <!-- 3D book cover -->
    <div class="cover-stage">
      <div class="cover">
        <div class="cover-edge" aria-hidden="true"></div>
        <div class="cover-front">
          <div class="cover-glow" aria-hidden="true"></div>
          <img class="cover-mark" src="/logo.png" alt="" aria-hidden="true" />
          <div class="cover-spine" aria-hidden="true"></div>
          <div class="cover-body">
            <div class="cover-press">Fractal Manifold Press</div>
            <div class="cover-bottom">
              <h2 class="cover-title gradient-text">Geometric Deep Learning</h2>
              <p class="cover-sub">{copy.heroTagline}</p>
              <div class="cover-rule"></div>
              <p class="cover-gs">Geometry · Groups · Graphs<br />Geodesics · Gauges</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== THESIS ===================== -->
<section id="thesis" class="band">
  <div class="shell">
    <div class="head">
      <div class="eyebrow">{copy.thesisEyebrow}</div>
      <h2 class="band-title">{copy.thesisTitle}</h2>
      <div class="rule"></div>
    </div>
    <p class="lead">{copy.thesisP1}</p>
    <p class="lead">{copy.thesisP2}</p>
    <blockquote class="pull">
      <p>{copy.thesisQuote}</p>
    </blockquote>
  </div>
</section>

<!-- ===================== THE 5 Gs ===================== -->
<section id="gs" class="band">
  <div class="shell">
    <div class="head">
      <div class="eyebrow">{copy.gsEyebrow}</div>
      <h2 class="band-title">{copy.gsTitle}</h2>
      <div class="rule"></div>
    </div>
    <div class="grid grid-gs">
      {fiveGs.map((g) => (
        <article class={`card ${g.accent}`}>
          <div class="badge"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={g.icon}></svg></div>
          <h3 class="card-title">{g.name}</h3>
          <p class="card-desc">{g.desc}</p>
        </article>
      ))}
      <article class="card dashed center">
        <p class="eyebrow blueprint">{copy.blueprintLabel}</p>
        <p class="card-desc light">{copy.blueprintDesc}</p>
      </article>
    </div>
  </div>
</section>

<!-- ===================== CONTENTS (list) ===================== -->
<section id="contents" class="band">
  <div class="shell">
    <div class="head">
      <div class="eyebrow">{copy.contentsEyebrow}</div>
      <h2 class="band-title">{copy.contentsTitle}</h2>
      <div class="rule"></div>
    </div>
    <ol class="toc-list">
      {chapters.map((c, i) => {
        const accent = i % 2 === 0 ? 'gold' : 'purple';
        return (
          <li class="toc-item">
            <a href={localizePath(`/chapters/${slugOf(c.id)}/`, lang)}>
              <span class={`toc-num ${accent}`}>{String(c.data.order).padStart(2, '0')}</span>
              <span class="toc-main">
                <span class="toc-title">{c.data.title}</span>
                {c.data.summary && <span class="toc-summary">{c.data.summary}</span>}
                {c.data.tags.length > 0 && (
                  <span class="tags">{c.data.tags.map((tag) => <span>{tag}</span>)}</span>
                )}
              </span>
              <span class="toc-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        );
      })}
    </ol>
    <p class="note">{copy.contentsNote}<a href={localizePath('/chapters/', lang)}>{t('chapters.read')}</a></p>
  </div>
</section>

<!-- ===================== AUDIENCE ===================== -->
<section id="audience" class="band">
  <div class="shell">
    <div class="head">
      <div class="eyebrow">{copy.audienceEyebrow}</div>
      <h2 class="band-title">{copy.audienceTitle}</h2>
      <div class="rule"></div>
    </div>
    <div class="grid grid-aud">
      {copy.audience.map((a) => (
        <article class="card gold pad">
          <h3 class="card-title md">{a.title}</h3>
          <p class="card-desc">{a.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ===================== GET THE BOOK ===================== -->
<section id="access" class="band access">
  <div class="access-orbs" aria-hidden="true">
    <div class="orb" style="width:420px;height:420px;opacity:0.3;background:radial-gradient(circle,#F59E0B,transparent);top:-30%;left:20%;animation:float-secondary 13s ease-in-out infinite"></div>
    <div class="orb" style="width:420px;height:420px;opacity:0.28;background:radial-gradient(circle,#9333EA,transparent);bottom:-30%;right:18%;animation:float-secondary 15s ease-in-out infinite reverse"></div>
  </div>
  <div class="shell access-inner">
    <div class="eyebrow">{copy.accessEyebrow}</div>
    <h2 class="band-title center">{copy.accessTitle}</h2>
    <div class="rule center-rule"></div>
    <p class="access-lead">{copy.accessLead}</p>
    <div class="grid grid-fmt">
      {formats.map((f) => {
        const inner = (
          <Fragment>
            <div class="badge"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}></svg></div>
            <div>
              <div class="fmt-title">{f.title}</div>
              <div class="fmt-desc">{f.desc}</div>
            </div>
            <div class="fmt-cta">{f.cta}</div>
          </Fragment>
        );
        return f.href ? (
          <a class={`card fmt ${f.accent}`} href={f.href} download rel="noopener">{inner}</a>
        ) : (
          <div class={`card fmt ${f.accent} disabled`}>{inner}</div>
        );
      })}
    </div>
    <p class="fine">{copy.accessFine}</p>
  </div>
</section>

<style>
  /* ---------------- HERO ---------------- */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 4rem 0;
  }
  .hero-orbs, .hero-math { position: absolute; inset: 0; z-index: 0; }
  .hero-math { overflow: hidden; }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 4.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero-text { flex: 1; min-width: 320px; max-width: 580px; }
  .eyebrow { margin-bottom: 1.4rem; }
  .hero-title {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    line-height: 1.18;
    letter-spacing: 1px;
    margin-bottom: 0.6rem;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.4vw, 1.5rem);
    color: var(--color-text-secondary);
    letter-spacing: 0.5px;
    margin-bottom: 1.6rem;
  }
  .hero-sub {
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2.4rem;
  }
  .hero-cta { display: flex; gap: 1.25rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .hero-by { font-size: 0.9rem; color: var(--color-text-muted); }

  .btn {
    font-weight: 600;
    letter-spacing: 0.5px;
    padding: 0.9rem 2rem;
    border-radius: 12px;
    border: 2px solid transparent;
    transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
  }
  .btn-gold { border-color: var(--color-gold); color: var(--color-gold); }
  .btn-gold:hover {
    background: var(--brand-gradient);
    color: var(--color-bg);
    border-color: transparent;
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(245, 158, 11, 0.3);
  }
  .btn-purple { border-color: var(--color-purple); color: var(--color-purple-light); }
  .btn-purple:hover {
    background: var(--color-purple);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 10px 40px rgba(147, 51, 234, 0.25);
  }

  /* ---- 3D book cover ---- */
  .cover-stage { flex: none; perspective: 1500px; padding: 1rem; }
  .cover {
    position: relative;
    width: 300px;
    height: 430px;
    transform: rotateY(-22deg) rotateX(3deg);
    transform-style: preserve-3d;
    transition: transform 0.6s ease;
  }
  .cover:hover { transform: rotateY(-10deg) rotateX(1deg); }
  .cover-edge {
    position: absolute;
    top: 6px; bottom: 6px; right: -15px;
    width: 16px;
    background: repeating-linear-gradient(180deg, #dcd6c7 0, #dcd6c7 2px, #b6af9d 2px, #b6af9d 3px);
    border-radius: 0 2px 2px 0;
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.4);
  }
  .cover-front {
    position: absolute;
    inset: 0;
    border-radius: 2px 8px 8px 2px;
    overflow: hidden;
    background: radial-gradient(130% 90% at 50% 0%, #1d1d1d, #0c0c0c);
    border: 1px solid rgba(243, 158, 11, 0.22);
    box-shadow: 34px 38px 70px rgba(0, 0, 0, 0.6), 0 0 50px rgba(147, 51, 234, 0.1);
  }
  .cover-glow {
    position: absolute;
    top: -25%; left: 50%;
    transform: translateX(-50%);
    width: 280px; height: 280px;
    border-radius: 50%;
    filter: blur(55px);
    opacity: 0.4;
    background: radial-gradient(circle, #9333EA, transparent);
  }
  .cover-mark {
    position: absolute;
    top: 48%; left: 50%;
    transform: translate(-50%, -50%);
    width: 215px;
    opacity: 0.5;
  }
  .cover-spine {
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 13px;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.65), rgba(255, 255, 255, 0.04));
    border-right: 1px solid rgba(245, 158, 11, 0.25);
  }
  .cover-body { position: absolute; inset: 0; padding: 2rem 1.6rem 1.8rem 2rem; display: flex; flex-direction: column; }
  .cover-press { font-family: var(--font-display); font-size: 0.5rem; letter-spacing: 2px; text-transform: uppercase; color: var(--color-text-muted); }
