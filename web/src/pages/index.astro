---
import BaseLayout from '../layouts/BaseLayout.astro';

const heroMath = [
  { t: 'f(g·x) = g·f(x)', c: 'var(--color-gold)', s: 'top:16%;left:6%', d: '0s', dur: '15s', size: '1.05rem' },
  { t: 'Σ_{j∈𝒩(i)} m_ij', c: 'var(--color-purple-light)', s: 'top:70%;left:8%', d: '-4s', dur: '18s', size: '1rem' },
  { t: 'ρ(g) ∈ GL(V)', c: 'var(--color-purple-light)', s: 'top:24%;right:7%', d: '-6s', dur: '17s', size: '0.95rem' },
  { t: 'SO(3), SE(3)', c: 'var(--color-gold)', s: 'bottom:14%;right:12%', d: '-2s', dur: '19s', size: '1rem' },
  { t: '∇_M f', c: 'var(--color-gold-light)', s: 'top:46%;left:3%', d: '-7s', dur: '16s', size: '0.95rem' },
];

const fiveGs = [
  { name: 'Geometry', accent: 'gold', desc: 'The domains of data. Euclidean and non-Euclidean spaces, the manifold hypothesis, and graphs as discrete geometry.',
    icon: '<circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>' },
  { name: 'Groups', accent: 'purple', desc: 'The symmetries of data. Lie groups, representations, and the equivariance that ties a network to its domain.',
    icon: '<polygon points="12 2 21 7 21 17 12 22 3 17 3 7"></polygon><line x1="12" y1="2" x2="12" y2="22"></line><line x1="3" y1="7" x2="21" y2="17"></line><line x1="21" y1="7" x2="3" y2="17"></line>' },
  { name: 'Graphs', accent: 'gold', desc: 'The discretization of geometry. The graph Laplacian, spectral analysis and topological deep learning.',
    icon: '<circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>' },
  { name: 'Geodesics', accent: 'purple', desc: 'Optimal paths and information flow. Riemannian metrics, connections, curvature and the exponential map.',
    icon: '<circle cx="6" cy="19" r="2"></circle><circle cx="18" cy="5" r="2"></circle><path d="M7.5 17.5C11 13 13 11 16.5 6.5"></path>' },
  { name: 'Gauges', accent: 'gold', desc: 'Local frames and coordinate freedom. Principal bundles, parallel transport and gauge-equivariant networks — the most general setting.',
    icon: '<circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>' },
];

const contents = [
  { n: '01', accent: 'gold', title: 'Introduction', desc: 'Why Euclidean methods lose information on graphs, surfaces and groups — and the single principle that fixes it.', tags: ['Non-Euclidean data', 'The 5 Gs', 'Objectives'] },
  { n: '02', accent: 'purple', title: 'Artificial Neural Networks', desc: 'From the artificial neuron to deep networks: signals over structured domains, layers as computational graphs, and the theory of learning and approximation.', tags: ['Activation & layers', 'Backpropagation', 'Universal approximation'] },
  { n: '03', accent: 'gold', title: 'Geometric Deep Learning', desc: 'The unifying framework. The five Gs, equivariance and invariance, homogeneous spaces, and message passing as the common language of every architecture.', tags: ['Equivariance', 'Homogeneous spaces', 'Message passing', 'Weisfeiler–Leman'] },
  { n: '04', accent: 'purple', title: 'Convolutional Models', desc: 'Convolutions from first principles: harmonic analysis, the CNN–GNN equivalence, group convolutions and gauge-equivariant networks on curved domains.', tags: ['Spectral convolutions', 'Group convolutions', 'SE(3)', 'Gauge CNNs'] },
  { n: '05', accent: 'gold', title: 'Geometric Attention', desc: 'Attention as geometry: equivariant transformers, attention on hyperbolic and spherical spaces, geometric algebra and topological attention.', tags: ['Equivariant attention', 'Hyperbolic & spherical', 'GATr', 'Simplicial'] },
  { n: '06', accent: 'purple', title: 'Conclusions', desc: 'What the framework unifies, where it breaks, and the open problems that remain.', tags: ['Synthesis', 'Open problems'] },
];

const appendix = { desc: 'Supporting results, from Gauss–Bonnet and Bishop–Günther to the isometries between models of hyperbolic space.', tags: ['Gauss–Bonnet', 'Bishop–Günther', 'Hyperbolic models', 'Spectral theorem'] };

const audience = [
  { title: 'Researchers', desc: 'A unifying language for architectures you already know, and a map of the open territory beyond them.' },
  { title: 'Engineers', desc: 'Principled reasons to choose one model over another, grounded in the structure of your own data.' },
  { title: 'Students', desc: 'A rigorous on-ramp: linear algebra and calculus in, modern deep learning out — with the maths kept honest.' },
];

// The book is still being written — every format is disabled ("Coming soon")
// until there is a real PDF/print edition to ship. Re-enable a format by
// setting its `href` to the release asset and changing `cta` to "Download →":
//   Screen PDF: https://github.com/fractal-manifold/gdl/releases/download/book-latest/geometric-deep-learning.pdf
//   Print PDF:  https://github.com/fractal-manifold/gdl/releases/download/book-latest/geometric-deep-learning-print.pdf
const formats = [
  { title: 'Screen PDF', desc: 'Optimised for reading on any screen', accent: 'gold', cta: 'Coming soon', href: null,
    icon: '<rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path>' },
  { title: 'Print PDF', desc: 'Print-ready, sized for 7×10″ paper', accent: 'gold', cta: 'Coming soon', href: null,
    icon: '<polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect>' },
  { title: 'ePub', desc: 'For Kindle, Kobo & e-readers', accent: 'purple', cta: 'Coming soon', href: null,
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>' },
  { title: 'Printed copy', desc: 'Order a bound edition on Amazon', accent: 'purple', cta: 'Coming soon', href: null,
    icon: '<circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>' },
];
---

<BaseLayout fullWidth>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero-orbs" aria-hidden="true">
      <div class="orb" style="width:520px;height:520px;opacity:0.4;background:radial-gradient(circle,#9333EA,transparent);top:-12%;left:-8%;animation:float-main 14s ease-in-out infinite"></div>
      <div class="orb" style="width:480px;height:480px;opacity:0.38;background:radial-gradient(circle,#F59E0B,transparent);bottom:-18%;right:-6%;animation:float-main 16s ease-in-out infinite reverse"></div>
      <div class="orb" style="width:300px;height:300px;opacity:0.3;background:radial-gradient(circle,#A855F7,transparent);top:30%;right:30%;animation:float-secondary 11s ease-in-out infinite;animation-delay:-3s"></div>
    </div>
    <div class="hero-math" aria-hidden="true">
      {heroMath.map((m) => (
        <span class="eq" style={`${m.s};color:${m.c};font-size:${m.size};animation:drift-eq ${m.dur} ease-in-out infinite;animation-delay:${m.d}`}>{m.t}</span>
      ))}
    </div>

    <div class="shell hero-inner">
      <div class="hero-text">
        <div class="eyebrow">Fractal Manifold Press · Book</div>
        <h1 class="hero-title"><span class="gradient-text">Geometric Deep Learning</span></h1>
        <p class="hero-sub">A math-first treatment of deep learning on graphs, manifolds and groups — message passing, symmetry and equivariance from the ground up.</p>
        <div class="hero-cta">
          <a class="btn btn-gold" href="#access">Get the book</a>
          <a class="btn btn-purple" href="#contents">Browse contents</a>
        </div>
        <div class="hero-by">By the Fractal Manifold research team · Free to download</div>
      </div>

      <!-- 3D book cover -->
      <div class="cover-stage">
        <div class="cover">
          <div class="cover-edge" aria-hidden="true"></div>
          <div class="cover-front">
            <div class="cover-glow" aria-hidden="true"></div>
            <img class="cover-mark" src="/logo.png" alt="" aria-hidden="true" />
            <div class="cover-spine" aria-hidden="true"></div>
            <div class="cover-body">
              <div class="cover-press">Fractal Manifold Press</div>
              <div class="cover-bottom">
                <h2 class="cover-title gradient-text">Geometric Deep Learning</h2>
                <div class="cover-rule"></div>
                <p class="cover-gs">Geometry · Groups · Graphs<br />Geodesics · Gauges</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== THESIS ===================== -->
  <section id="thesis" class="band">
    <div class="shell">
      <div class="head">
        <div class="eyebrow">01 — The Thesis</div>
        <h2 class="band-title">An Erlangen Programme for deep learning</h2>
        <div class="rule"></div>
      </div>
      <p class="lead">Most successful neural networks share a hidden blueprint: they are built to respect the symmetries of the data they consume. A convolutional network is invariant to translation; a graph network to permutation; a spherical network to rotation.</p>
      <p class="lead">Geometric Deep Learning makes that blueprint explicit. Starting from a small set of geometric priors — symmetry, scale separation and locality — it derives the architectures that dominate practice today, and points toward the ones that don't yet exist.</p>
      <blockquote class="pull">
        <p>Symmetry is not a constraint on learning — it is the structure that makes learning possible.</p>
      </blockquote>
    </div>
  </section>

  <!-- ===================== THE 5 Gs ===================== -->
  <section id="gs" class="band">
    <div class="shell">
      <div class="head">
        <div class="eyebrow">02 — The Five Gs</div>
        <h2 class="band-title">Five domains, one set of principles</h2>
        <div class="rule"></div>
      </div>
      <div class="grid grid-gs">
        {fiveGs.map((g) => (
          <article class={`card ${g.accent}`}>
            <div class="badge"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={g.icon}></svg></div>
            <h3 class="card-title">{g.name}</h3>
            <p class="card-desc">{g.desc}</p>
          </article>
        ))}
        <article class="card dashed center">
          <p class="eyebrow blueprint">The blueprint</p>
          <p class="card-desc light">Each domain is a special case of one recipe: a symmetry group, a signal on a domain, and equivariant maps that commute with the group. Message passing is its common implementation.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================== CONTENTS ===================== -->
  <section id="contents" class="band">
    <div class="shell">
      <div class="head">
        <div class="eyebrow">03 — Contents</div>
        <h2 class="band-title">Table of contents</h2>
        <div class="rule"></div>
      </div>
      <div class="grid grid-toc">
        {contents.map((c) => (
          <article class={`card ${c.accent}`}>
            <div class="toc-head">
              <span class={`num ${c.accent}`}>{c.n}</span>
              <h3 class="card-title sm">{c.title}</h3>
            </div>
            <p class="card-desc">{c.desc}</p>
            <div class="tags">{c.tags.map((t) => <span>{t}</span>)}</div>
          </article>
        ))}
        <article class="card dashed full">
          <div class="toc-head">
            <span class="num amber">A</span>
            <h3 class="card-title sm">Appendix — Complementary theorems &amp; proofs</h3>
          </div>
          <p class="card-desc">{appendix.desc}</p>
          <div class="tags">{appendix.tags.map((t) => <span>{t}</span>)}</div>
        </article>
      </div>
      <p class="note">Six chapters and a complementary appendix — a rigorous path from artificial neurons to gauge theory. <a href="/chapters/">Read the chapters online →</a></p>
    </div>
  </section>

  <!-- ===================== AUDIENCE ===================== -->
  <section id="audience" class="band">
    <div class="shell">
      <div class="head">
        <div class="eyebrow">04 — Who it's for</div>
        <h2 class="band-title">Written for builders and theorists alike</h2>
        <div class="rule"></div>
      </div>
      <div class="grid grid-aud">
        {audience.map((a) => (
          <article class="card gold pad">
            <h3 class="card-title md">{a.title}</h3>
            <p class="card-desc">{a.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== GET THE BOOK ===================== -->
  <section id="access" class="band access">
    <div class="access-orbs" aria-hidden="true">
      <div class="orb" style="width:420px;height:420px;opacity:0.3;background:radial-gradient(circle,#F59E0B,transparent);top:-30%;left:20%;animation:float-secondary 13s ease-in-out infinite"></div>
      <div class="orb" style="width:420px;height:420px;opacity:0.28;background:radial-gradient(circle,#9333EA,transparent);bottom:-30%;right:18%;animation:float-secondary 15s ease-in-out infinite reverse"></div>
    </div>
    <div class="shell access-inner">
      <div class="eyebrow">05 — Get the book</div>
      <h2 class="band-title center">Get the book</h2>
      <div class="rule center-rule"></div>
      <p class="access-lead">The book is still being written. Free screen and print PDFs, an ePub for e-readers, and a bound edition on Amazon will all be published here as soon as the first release is ready.</p>
      <div class="grid grid-fmt">
        {formats.map((f) => {
          const inner = (
            <Fragment>
              <div class="badge"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}></svg></div>
              <div>
                <div class="fmt-title">{f.title}</div>
                <div class="fmt-desc">{f.desc}</div>
              </div>
              <div class="fmt-cta">{f.cta}</div>
            </Fragment>
          );
          return f.href ? (
            <a class={`card fmt ${f.accent}`} href={f.href} download rel="noopener">{inner}</a>
          ) : (
            <div class={`card fmt ${f.accent} disabled`}>{inner}</div>
          );
        })}
      </div>
      <p class="fine">Digital formats will be published on GitHub Releases. The printed edition will link to Amazon.</p>
    </div>
  </section>

  <style>
    /* ---------------- HERO ---------------- */
    .hero {
      position: relative;
      min-height: 90vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      padding: 4rem 0;
    }
    .hero-orbs, .hero-math { position: absolute; inset: 0; z-index: 0; }
    .hero-math { overflow: hidden; }
    .hero-inner {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 4.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .hero-text { flex: 1; min-width: 320px; max-width: 580px; }
    .eyebrow { margin-bottom: 1.4rem; }
    .hero-title {
      font-size: clamp(2.6rem, 6vw, 4.4rem);
      line-height: 1.18;
      letter-spacing: 1px;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: clamp(1.1rem, 2.2vw, 1.4rem);
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin-bottom: 2.4rem;
    }
    .hero-cta { display: flex; gap: 1.25rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .hero-by { font-size: 0.9rem; color: var(--color-text-muted); }

    .btn {
      font-weight: 600;
      letter-spacing: 0.5px;
      padding: 0.9rem 2rem;
      border-radius: 12px;
      border: 2px solid transparent;
      transition: transform 0.3s ease, background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    }
    .btn-gold { border-color: var(--color-gold); color: var(--color-gold); }
    .btn-gold:hover {
      background: var(--brand-gradient);
      color: var(--color-bg);
      border-color: transparent;
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(245, 158, 11, 0.3);
    }
    .btn-purple { border-color: var(--color-purple); color: var(--color-purple-light); }
    .btn-purple:hover {
      background: var(--color-purple);
      color: #fff;
      transform: translateY(-3px);
      box-shadow: 0 10px 40px rgba(147, 51, 234, 0.25);
    }

    /* ---- 3D book cover ---- */
    .cover-stage { flex: none; perspective: 1500px; padding: 1rem; }
    .cover {
      position: relative;
      width: 300px;
      height: 430px;
      transform: rotateY(-22deg) rotateX(3deg);
      transform-style: preserve-3d;
      transition: transform 0.6s ease;
    }
    .cover:hover { transform: rotateY(-10deg) rotateX(1deg); }
    .cover-edge {
      position: absolute;
      top: 6px; bottom: 6px; right: -15px;
      width: 16px;
      background: repeating-linear-gradient(180deg, #dcd6c7 0, #dcd6c7 2px, #b6af9d 2px, #b6af9d 3px);
      border-radius: 0 2px 2px 0;
      box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.4);
    }
    .cover-front {
      position: absolute;
      inset: 0;
      border-radius: 2px 8px 8px 2px;
      overflow: hidden;
      background: radial-gradient(130% 90% at 50% 0%, #1d1d1d, #0c0c0c);
      border: 1px solid rgba(243, 158, 11, 0.22);
      box-shadow: 34px 38px 70px rgba(0, 0, 0, 0.6), 0 0 50px rgba(147, 51, 234, 0.1);
    }
    .cover-glow {
      position: absolute;
      top: -25%; left: 50%;
      transform: translateX(-50%);
      width: 280px; height: 280px;
      border-radius: 50%;
      filter: blur(55px);
      opacity: 0.4;
      background: radial-gradient(circle, #9333EA, transparent);
    }
    .cover-mark {
      position: absolute;
      top: 48%; left: 50%;
      transform: translate(-50%, -50%);
      width: 215px;
      opacity: 0.5;
    }
    .cover-spine {
      position: absolute;
      top: 0; bottom: 0; left: 0;
      width: 13px;
      background: linear-gradient(90deg, rgba(0, 0, 0, 0.65), rgba(255, 255, 255, 0.04));
      border-right: 1px solid rgba(245, 158, 11, 0.25);
    }
    .cover-body { position: absolute; inset: 0; padding: 2rem 1.6rem 1.8rem 2rem; display: flex; flex-direction: column; }
    .cover-press { font-family: var(--font-display); font-size: 0.5rem; letter-spacing: 2px; text-transform: uppercase; color: var(--color-text-muted); }
    .cover-bottom { margin-top: auto; position: relative; z-index: 1; }
    .cover-title { font-family: var(--font-display); font-size: 1.55rem; line-height: 1.22; }
    .cover-rule { height: 2px; width: 54px; background: linear-gradient(90deg, #F59E0B, #9333EA); border-radius: 2px; margin: 0.9rem 0; }
    .cover-gs { color: var(--color-text-secondary); font-size: 0.6rem; letter-spacing: 1.5px; text-transform: uppercase; font-family: var(--font-display); line-height: 1.6; }

    /* ---------------- BANDS ---------------- */
    .band { padding: 6rem 0; position: relative; }
    .head { margin-bottom: 3rem; }
    .head .eyebrow { margin-bottom: 1rem; }
    .band-title { font-size: clamp(2.2rem, 4.5vw, 3.2rem); line-height: 1.25; margin-bottom: 1rem; max-width: 900px; }
    .rule { margin-top: 0; }
    .lead { font-size: 1.3rem; color: var(--color-text-secondary); line-height: 1.8; max-width: 840px; margin-bottom: 1.5rem; }
    .pull {
      max-width: 840px;
      border-left: 3px solid;
      border-image: linear-gradient(180deg, #F59E0B, #9333EA) 1;
      padding: 0.5rem 0 0.5rem 2rem;
      margin: 1.5rem 0 0;
    }
    .pull p { font-family: var(--font-display); font-size: clamp(1.3rem, 2.6vw, 1.8rem); line-height: 1.5; color: #fff; }

    /* ---------------- CARDS ---------------- */
    .grid { display: grid; gap: 1.5rem; }
    .grid-gs { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
    .grid-toc { grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); align-items: start; }
    .grid-aud { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
    .grid-fmt { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; text-align: left; margin-top: 0.5rem; }

    .card {
      position: relative;
      overflow: hidden;
      padding: 1.75rem;
      background: rgba(26, 26, 26, 0.5);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid var(--cb, var(--color-border));
      border-radius: 16px;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .card.pad { padding: 2rem; }
    .card.gold { --cb: rgba(243, 158, 11, 0.12); --cbs: rgba(243, 158, 11, 0.32); --cglow: 0 10px 40px rgba(245, 158, 11, 0.08); }
    .card.purple { --cb: rgba(168, 85, 247, 0.14); --cbs: rgba(168, 85, 247, 0.34); --cglow: 0 10px 40px rgba(147, 51, 234, 0.08); }
    .card.gold:hover, .card.purple:hover { transform: translateY(-5px); border-color: var(--cbs); box-shadow: var(--cglow); }
    .card.dashed { background: rgba(26, 26, 26, 0.35); border: 1px dashed rgba(255, 255, 255, 0.13); }
    .card.center { display: flex; flex-direction: column; justify-content: center; }
    .card.full { grid-column: 1 / -1; }

    .badge {
      display: flex; align-items: center; justify-content: center;
      width: 48px; height: 48px;
      border-radius: 12px;
      border: 1px solid;
      margin-bottom: 1.1rem;
    }
    .gold .badge { border-color: rgba(243, 158, 11, 0.3); background: rgba(245, 158, 11, 0.07); color: var(--color-gold); }
    .purple .badge { border-color: rgba(168, 85, 247, 0.3); background: rgba(168, 85, 247, 0.07); color: var(--color-purple-light); }

    .card-title { font-family: var(--font-display); font-size: 1.2rem; color: #fff; margin-bottom: 0.6rem; }
    .card-title.sm { font-size: 1.12rem; margin-bottom: 0; line-height: 1.3; }
    .card-title.md { font-size: 1.25rem; margin-bottom: 0.75rem; }
    .card-desc { color: var(--color-text-muted); line-height: 1.6; font-size: 0.96rem; }
    .card-desc.light { color: var(--color-text-secondary); }
    .blueprint { font-size: 0.62rem; margin-bottom: 0.7rem; }

    .toc-head { display: flex; align-items: baseline; gap: 0.9rem; margin-bottom: 0.7rem; }
    .num { font-family: var(--font-display); font-variant-numeric: tabular-nums; font-size: 1.35rem; line-height: 1; }
    .num.gold { color: var(--color-gold); }
    .num.purple { color: var(--color-purple-light); }
    .num.amber { color: var(--color-gold-light); font-size: 0.95rem; letter-spacing: 1px; }
    .card-desc + .tags { margin-top: 1rem; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tags span {
      font-size: 0.72rem;
      color: var(--color-text-secondary);
