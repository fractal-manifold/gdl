---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const chapters = (await getCollection('chapters')).sort(
  (a, b) => a.data.order - b.data.order,
);

const gs = [
  { g: 'Grids', d: 'Convolutional networks and translation symmetry.' },
  { g: 'Groups', d: 'Equivariance to rotations, reflections, and more.' },
  { g: 'Graphs', d: 'Permutation-equivariant message passing.' },
  { g: 'Geodesics', d: 'Learning on curved manifolds.' },
  { g: 'Gauges', d: 'Local frames and gauge equivariance.' },
];
---

<BaseLayout>
  <section class="hero">
    <p class="eyebrow">A book in progress</p>
    <h1>Geometric Deep Learning</h1>
    <p class="lede">
      Grids, Groups, Graphs, Geodesics, and Gauges — a unified, symmetry-first
      account of modern deep learning architectures.
    </p>
    <div class="cta">
      <a class="btn" href="/chapters/">Read the chapters</a>
      <a class="btn ghost" href="https://github.com/">View source</a>
    </div>
  </section>

  <section class="grid">
    {gs.map((x) => (
      <div class="card">
        <h3>{x.g}</h3>
        <p>{x.d}</p>
      </div>
    ))}
  </section>

  <section>
    <h2>Table of contents</h2>
    <ol class="toc">
      {chapters.map((c) => (
        <li>
          <a href={`/chapters/${c.id}/`}>{c.data.title}</a>
          {c.data.draft && <span class="tag">draft</span>}
        </li>
      ))}
    </ol>
  </section>

  <style>
    .hero { padding: 3rem 0 2rem; }
    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.8rem;
      color: var(--accent);
    }
    .hero h1 { font-size: clamp(2rem, 6vw, 3.25rem); margin: 0.25rem 0; }
    .lede { color: var(--muted); font-size: 1.15rem; max-width: 38rem; }
    .cta { display: flex; gap: 0.75rem; margin-top: 1.5rem; flex-wrap: wrap; }
    .btn {
      background: var(--accent-strong);
      color: #06283d;
      font-weight: 600;
      padding: 0.6rem 1.1rem;
      border-radius: 8px;
    }
    .btn:hover { text-decoration: none; background: var(--accent); }
    .btn.ghost { background: transparent; color: var(--fg); border: 1px solid var(--border); }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1rem;
      margin: 2.5rem 0;
    }
    .card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }
    .card h3 { margin: 0 0 0.35rem; color: var(--accent); }
    .card p { margin: 0; color: var(--muted); font-size: 0.92rem; }
    .toc { line-height: 2; }
    .tag {
      margin-left: 0.5rem;
      font-size: 0.7rem;
      text-transform: uppercase;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.05rem 0.5rem;
    }
  </style>
</BaseLayout>
