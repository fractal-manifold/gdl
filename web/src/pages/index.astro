---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const chapters = (await getCollection('chapters')).sort(
  (a, b) => a.data.order - b.data.order,
);

const gs = [
  { g: 'Grids', d: 'Convolutional networks and translation symmetry.' },
  { g: 'Groups', d: 'Equivariance to rotations, reflections, and more.' },
  { g: 'Graphs', d: 'Permutation-equivariant message passing.' },
  { g: 'Geodesics', d: 'Learning on curved manifolds.' },
  { g: 'Gauges', d: 'Local frames and gauge equivariance.' },
];

const RELEASE = 'https://github.com/fractal-manifold/gdl/releases/download/book-latest';
const PDF_URL = `${RELEASE}/geometric-deep-learning.pdf`;

const editions = [
  { name: 'PDF · A4', desc: 'Screen edition — read on desktop or tablet, print at home.', href: PDF_URL, status: 'Download' },
  { name: 'Read online', desc: 'The full book on the web, with searchable chapters.', href: '/chapters/', status: 'Open' },
  { name: 'Print · 7×10″', desc: 'Print-on-demand physical edition.', href: null, status: 'Coming soon' },
];
---

<BaseLayout>
  <section class="hero">
    <p class="eyebrow">A book in progress</p>
    <h1>Geometric<br /><span class="gradient-text">Deep Learning</span></h1>
    <p class="lede">
      Grids, Groups, Graphs, Geodesics, and Gauges — a unified, symmetry-first
      account of modern deep learning architectures.
    </p>
    <div class="cta">
      <a class="btn" href={PDF_URL} download rel="noopener">Download PDF</a>
      <a class="btn ghost" href="/chapters/">Read the chapters</a>
      <a class="btn ghost" href="https://github.com/fractal-manifold/gdl">View source</a>
    </div>
  </section>

  <section class="grid">
    {gs.map((x) => (
      <div class="card">
        <h3>{x.g}</h3>
        <p>{x.d}</p>
      </div>
    ))}
  </section>

  <section>
    <h2>Editions</h2>
    <div class="editions">
      {editions.map((e) => (
        <div class="edition">
          <div>
            <h3>{e.name}</h3>
            <p>{e.desc}</p>
          </div>
          {e.href ? (
            <a class="edition-btn" href={e.href} download={e.status === 'Download' ? true : undefined}>
              {e.status}
            </a>
          ) : (
            <span class="edition-soon">{e.status}</span>
          )}
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2>Table of contents</h2>
    <ol class="toc">
      {chapters.map((c) => (
        <li>
          <a href={`/chapters/${c.id}/`}>{c.data.title}</a>
          {c.data.draft && <span class="tag">draft</span>}
        </li>
      ))}
    </ol>
  </section>

  <style>
    .hero { padding: 4rem 0 2.5rem; }
    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 0.75rem;
      color: var(--color-gold);
      font-family: var(--font-display);
    }
    .hero h1 {
      font-size: clamp(2.4rem, 7vw, 4rem);
      margin: 0.5rem 0;
      letter-spacing: 0.02em;
    }
    .lede {
      color: var(--color-text-secondary);
      font-size: 1.2rem;
      max-width: 38rem;
    }
    .cta { display: flex; gap: 0.85rem; margin-top: 2rem; flex-wrap: wrap; }
    .btn {
      background: var(--color-gold);
      color: var(--color-bg);
      font-weight: 600;
      padding: 0.7rem 1.25rem;
      border-radius: 8px;
      transition: background 0.15s ease;
    }
    .btn:hover { text-decoration: none; background: var(--color-gold-light); }
    .btn.ghost {
      background: transparent;
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    .btn.ghost:hover { border-color: var(--color-gold); color: var(--color-gold); background: transparent; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(165px, 1fr));
      gap: 1rem;
      margin: 3rem 0;
    }
    .card {
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1.25rem;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .card:hover { border-color: var(--color-gold); transform: translateY(-2px); }
    .card h3 { margin: 0 0 0.4rem; color: var(--color-gold); font-size: 1.05rem; }
    .card p { margin: 0; color: var(--color-text-muted); font-size: 0.92rem; }
    .editions { display: grid; gap: 0.75rem; margin: 1.5rem 0 0; }
    .edition {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
    }
    .edition h3 { margin: 0 0 0.2rem; font-size: 1rem; }
    .edition p { margin: 0; color: var(--color-text-muted); font-size: 0.9rem; }
    .edition-btn {
      flex: none;
      background: var(--color-gold);
      color: var(--color-bg);
      font-weight: 600;
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
      border-radius: 8px;
    }
    .edition-btn:hover { text-decoration: none; background: var(--color-gold-light); }
    .edition-soon {
      flex: none;
      color: var(--color-purple-light);
      border: 1px solid var(--color-purple);
      border-radius: 999px;
      font-size: 0.75rem;
      letter-spacing: 0.04em;
      padding: 0.35rem 0.85rem;
    }
    .toc { line-height: 2.1; }
    .tag {
      margin-left: 0.5rem;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-purple-light);
      border: 1px solid var(--color-purple);
      border-radius: 999px;
      padding: 0.1rem 0.55rem;
    }
  </style>
</BaseLayout>
